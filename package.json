{
  "name": "item-thing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "prepare": "lefthook install",
    "dev": "concurrently -n web,convex -c blue,magenta \"pnpm dev:web\" \"pnpm dev:convex\"",
    "dev:web": "next dev --turbopack",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@jsquash/oxipng": "^2.3.0",
    "@sparticuz/chromium-min": "143.0.4",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.1",
    "html-to-image": "^1.11.13",
    "next": "16.1.7",
    "puppeteer-core": "24.35.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.8",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook",
      "puppeteer",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "@sparticuz/chromium": "143.0.4",
    "lefthook": "^2.1.4",
    "puppeteer": "24.35.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
